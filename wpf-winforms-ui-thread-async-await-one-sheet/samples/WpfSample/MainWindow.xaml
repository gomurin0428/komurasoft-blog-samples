<Window x:Class="WpfSample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF UIスレッドと async/await のサンプル" Height="560" Width="640">
    <StackPanel Margin="12">

        <!-- 4.1 UI イベントハンドラで plain await -->
        <TextBlock Text="4.1 plain await（ファイルを読み込んでプレビュー）" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBox x:Name="FilePathTextBox" Margin="0,0,0,4"/>
        <Button x:Name="LoadButton" Content="読み込み" Click="LoadButton_Click" Margin="0,0,0,4"/>

        <!-- 4.2 重い CPU 計算だけ Task.Run -->
        <TextBlock Text="4.2 Task.Run（SHA-256 ハッシュ計算）" FontWeight="Bold" Margin="0,8,0,4"/>
        <TextBox x:Name="InputPathTextBox" Margin="0,0,0,4"/>
        <Button x:Name="HashButton" Content="ハッシュ計算" Click="HashButton_Click" Margin="0,0,0,4"/>
        <TextBlock x:Name="ResultText" Margin="0,0,0,4"/>

        <!-- 4.3 ライブラリは ConfigureAwait(false)、UI 側は plain await -->
        <TextBlock Text="4.3 ライブラリ + plain await（改行を正規化して読み込み）" FontWeight="Bold" Margin="0,8,0,4"/>
        <TextBox x:Name="PathTextBox" Margin="0,0,0,4"/>
        <Button x:Name="OpenButton" Content="開く" Click="OpenButton_Click" Margin="0,0,0,4"/>

        <!-- 5 章: ConfigureAwait(false) の後で Dispatcher.InvokeAsync で UI に戻す -->
        <TextBlock Text="5章 Dispatcher.InvokeAsync（明示的に UI へ戻す）" FontWeight="Bold" Margin="0,8,0,4"/>
        <Button x:Name="RefreshButton" Content="プレビュー更新" Click="RefreshButton_Click" Margin="0,0,0,4"/>

        <TextBlock x:Name="StatusText" Margin="0,8,0,4"/>
        <TextBox x:Name="PreviewTextBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 Height="180" IsReadOnly="True"/>
    </StackPanel>
</Window>
